{
    "name": "remark-mdx-mermaid",
    "version": "1.1.1",
    "description": "A remark plugin for MDX that transforms fenced `mermaid` code blocks into `<Mermaid>` JSX elements, paired with a `useMermaid` React hook that handles rendering.",
    "type": "module",
    "exports": {
        "./react": {
            "require": "./dist/react.cjs",
            "import": "./dist/react.js",
            "types": "./dist/react.d.ts"
        },
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@types/mdast": "^4.0.4",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "tsup": "^8.5.1",
        "typescript": "^5"
    },
    "dependencies": {
        "mdast-util-mdx": "^3.0.0",
        "mermaid": "^11.14.0",
        "unist-util-visit": "^5.1.0"
    },
    "peerDependencies": {
        "react": "^18 || ^19"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/posroe/remark-mdx-mermaid.git"
    },
    "license": "MIT",
    "keywords": [
        "mdx",
        "mermaid",
        "remark",
        "unified",
        "diagram",
        "flowchart",
        "graph",
        "svg",
        "markdown",
        "remark-plugin",
        "remark-mdx-mermaid"
    ]
}